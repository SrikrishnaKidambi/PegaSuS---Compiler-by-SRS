Entity Point {

    public int x;
    public int y;

    Point() {
        x = 0;
        y = 0;
    }

    Point(int a) {
        x = a;
        y = 0;
    }

    Point(int a, int b) {
        x = a;
        y = b;
    }
}

Point p1 = new Point();
Point p2 = new Point(5);
Point p3 = new Point(3,4);
